<Bindings>
    <Binding name="CW_TOGGLE_KNOWN_LOCATIONS" header="CUSTOMWAYPOINTS">
        if CustomWaypoints_ToggleKnownLocations then
            CustomWaypoints_ToggleKnownLocations()
        end
    </Binding>
    <Binding name="CW_SAVE_HERE" header="CUSTOMWAYPOINTS">
        if CustomWaypoints_SaveHere then
            CustomWaypoints_SaveHere()
        end
    </Binding>
    <Binding name="CW_CLEAR_QUEUE" header="CUSTOMWAYPOINTS">
        if CW_CLEAR_QUEUE then
            CW_CLEAR_QUEUE()
        end
    </Binding>
    <Binding name="CW_UNDO" header="CUSTOMWAYPOINTS">
        if CW_UNDO then
            CW_UNDO()
        end
    </Binding>

    <Binding name="CW_REDO" header="CUSTOMWAYPOINTS">
        if CW_REDO then
            CW_REDO()
        end
    </Binding>
    <Binding name="CW_DELETE_SELECTED_KNOWN_LOCATION" header="CUSTOMWAYPOINTS">
        CW_DELETE_SELECTED_KNOWN_LOCATION()
    </Binding>
</Bindings>
